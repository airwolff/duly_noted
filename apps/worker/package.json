{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint src scripts",
    "test": "vitest run",
    "backfill:embeddings": "tsx --env-file=.env.local scripts/backfill-embeddings.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@duly-noted/db": "workspace:*",
    "@duly-noted/shared": "workspace:*",
    "@supabase/supabase-js": "^2.105.3",
    "zod": "^3.23.8"
  }
}
